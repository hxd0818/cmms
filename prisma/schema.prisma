// CMMS Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ System ============

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         SystemRole @default(VIEWER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

enum SystemRole {
  SUPER_ADMIN
  VIEWER
}

// ============ Guest ============

model Guest {
  id          String     @id @default(cuid())
  name        String
  gender      Gender?
  phone       String?    @unique
  email       String?
  company     String?
  title       String?
  level       GuestLevel @default(C)
  avatarUrl   String?
  idNumber    String?
  dietaryTags String[]
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  meetingGuests MeetingGuest[]

  @@index([name])
  @@index([company])
  @@map("guests")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GuestLevel {
  VIP_A
  VIP_B
  A
  B
  C
}

// ============ Meeting ============

model Meeting {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  status      MeetingStatus @default(DRAFT)
  startAt     DateTime
  endAt       DateTime
  venue       String?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  meetingGuests MeetingGuest[]
  agendaItems   AgendaItem[]

  @@index([status, startAt])
  @@map("meetings")
}

enum MeetingStatus {
  DRAFT
  PLANNING
  ONGOING
  COMPLETED
  CANCELED
}

model MeetingGuest {
  id                    String         @id @default(cuid())
  meetingId             String
  guestId               String
  rsvpStatus            RsvpStatus     @default(PENDING)
  groupTags             String[]
  receptionStage        ReceptionStage @default(NOT_ARRIVED)
  primaryMeetingGuestId String?
  entourageRole         EntourageRole?
  levelOverride         GuestLevel?
  inheritLodging        Boolean        @default(true)
  inheritTransport      Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  meeting      Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  guest        Guest         @relation(fields: [guestId], references: [id])
  primary      MeetingGuest? @relation("EntourageRelation", fields: [primaryMeetingGuestId], references: [id])
  subordinates MeetingGuest[] @relation("EntourageRelation")
  transportOrders TransportOrder[]
  lodgingOrders  LodgingOrder[]
  cateringOrders CateringOrder[]
  giftOrders     GiftOrder[]

  @@unique([meetingId, guestId])
  @@index([meetingId, receptionStage])
  @@index([guestId])
  @@map("meeting_guests")
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum ReceptionStage {
  NOT_ARRIVED
  CHECKED_IN
  IN_HOUSE
  DEPARTED
  NO_SHOW
}

enum EntourageRole {
  PRIMARY
  SECRETARY
  SECURITY
  INTERPRETER
  FAMILY
  AIDE
  DRIVER
}

// ============ Forward declarations (full schemas added in their own phases) ============

// AgendaItem will be fully defined in M2.2 (Phase 2 Task 2.2.1)


// ============ AgendaItem ============

model AgendaItem {
  id         String    @id @default(cuid())
  meetingId  String
  title      String
  type       AgendaType
  startAt    DateTime
  endAt      DateTime
  venue      String?
  speakerIds String[]
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, startAt])
  @@map("agenda_items")
}

enum AgendaType {
  KEYNOTE
  PANEL
  BREAK
  MEAL
  TOUR
  OTHER
}

// ============ Vehicle (resource pool) ============

model Vehicle {
  id          String      @id @default(cuid())
  plateNo     String      @unique
  type        VehicleType
  capacity    Int
  driverName  String
  driverPhone String
  belongs     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  transportOrders TransportOrder[]

  @@map("vehicles")
}

enum VehicleType {
  SEDAN
  MPV
  BUS
  OTHER
}

// ============ TransportOrder ============

model TransportOrder {
  id              String          @id @default(cuid())
  meetingId       String
  meetingGuestId  String
  vehicleId       String?
  pickupType      PickupType
  pickupLocation  String
  pickupTime      DateTime
  dropoffLocation String
  flightNo        String?
  status          TransportStatus @default(UNASSIGNED)
  actualPickupAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  meetingGuest MeetingGuest @relation(fields: [meetingGuestId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@index([meetingId, pickupTime])
  @@index([vehicleId, pickupTime])
  @@map("transport_orders")
}

enum PickupType {
  AIRPORT
  TRAINSTATION
  HOTEL
  VENUE
}

enum TransportStatus {
  UNASSIGNED
  ASSIGNED
  EN_ROUTE
  PICKED_UP
  COMPLETED
  REASSIGNED
  CANCELED
}

// ============ Access Tokens (portals) ============

model GuestAccessToken {
  id              String   @id @default(cuid())
  meetingGuestId  String   @unique
  tokenHash       String   @unique
  issuedAt        DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedBy       String?
  lastAccessedAt  DateTime?
  accessCount     Int      @default(0)

  @@index([expiresAt])
  @@map("guest_access_tokens")
}

model DriverAccessToken {
  id               String   @id @default(cuid())
  transportOrderId String   @unique
  tokenHash        String   @unique
  issuedAt         DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@map("driver_access_tokens")
}

// ============ Lodging ============

model Hotel {
  id          String      @id @default(cuid())
  name        String
  address     String
  contactPhone String?
  rooms       HotelRoom[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("hotels")
}

model HotelRoom {
  id         String     @id @default(cuid())
  hotelId    String
  roomNumber String
  roomType   RoomType
  status     RoomStatus @default(AVAILABLE)
  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  lodgingOrders LodgingOrder[]

  @@unique([hotelId, roomNumber])
  @@map("hotel_rooms")
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
}

model LodgingOrder {
  id               String        @id @default(cuid())
  meetingId        String
  meetingGuestId   String
  hotelRoomId      String?
  checkInAt        DateTime
  checkOutAt       DateTime
  specialRequests  String?
  status           LodgingStatus @default(UNASSIGNED)
  roommateIds      String[]
  actualCheckInAt  DateTime?
  actualCheckOutAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  meetingGuest MeetingGuest @relation(fields: [meetingGuestId], references: [id], onDelete: Cascade)
  hotelRoom    HotelRoom?   @relation(fields: [hotelRoomId], references: [id])

  @@index([meetingId, checkInAt])
  @@index([hotelRoomId, checkInAt])
  @@map("lodging_orders")
}

enum LodgingStatus {
  UNASSIGNED
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  ROOM_CHANGED
  CANCELED
}

// ============ Catering ============

model DiningTable {
  id             String          @id @default(cuid())
  meetingId      String
  name           String
  capacity       Int
  type           TableType
  cateringOrders CateringOrder[]

  @@map("dining_tables")
}

enum TableType {
  ROUND
  SQUARE
  BUFFET
}

model CateringOrder {
  id             String          @id @default(cuid())
  meetingId      String
  meetingGuestId String
  mealType       MealType
  mealTime       DateTime
  diningTableId  String?
  specialDietary String[]
  status         CateringStatus  @default(SCHEDULED)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  meetingGuest MeetingGuest @relation(fields: [meetingGuestId], references: [id], onDelete: Cascade)
  diningTable  DiningTable?  @relation(fields: [diningTableId], references: [id])

  @@index([meetingId, mealTime])
  @@map("catering_orders")
}

enum MealType {
  WELCOME_BANQUET
  FAREWELL
  LUNCH
  DINNER
  BREAKFAST
}

enum CateringStatus {
  SCHEDULED
  SEATED
  FINISHED
  CANCELED
}

// ============ Gift + Companion + Fee ============

model Gift {
  id        String      @id @default(cuid())
  name      String
  stock     Int
  unitPrice Decimal?    @db.Decimal(10, 2)
  giftOrders GiftOrder[]

  @@map("gifts")
}

model GiftOrder {
  id             String     @id @default(cuid())
  meetingId      String
  meetingGuestId String
  giftId         String
  quantity       Int        @default(1)
  status         GiftStatus @default(PENDING)
  deliveredAt    DateTime?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  meetingGuest MeetingGuest @relation(fields: [meetingGuestId], references: [id], onDelete: Cascade)
  gift         Gift         @relation(fields: [giftId], references: [id])

  @@map("gift_orders")
}

enum GiftStatus {
  PENDING
  DELIVERED
  CANCELED
}

model Companion {
  id         String               @id @default(cuid())
  name       String
  phone      String?
  languages  String[]
  role       String
  assignments CompanionAssignment[]

  @@map("companions")
}

model CompanionAssignment {
  id              String   @id @default(cuid())
  meetingId       String
  meetingGuestId  String
  companionId     String
  assignmentScope String
  notes           String?
  createdAt       DateTime @default(now())

  companion Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@unique([meetingGuestId, companionId, assignmentScope])
  @@map("companion_assignments")
}

model FeeRecord {
  id             String      @id @default(cuid())
  meetingId      String
  meetingGuestId String?
  category       FeeCategory
  amount         Decimal     @db.Decimal(10, 2)
  currency       String      @default("CNY")
  incurredAt     DateTime    @default(now())
  notes          String?
  createdBy      String
  createdAt      DateTime    @default(now())

  @@index([meetingId, category])
  @@map("fee_records")
}

enum FeeCategory {
  TRANSPORT
  LODGING
  MEAL
  GIFT
  OTHER
}


